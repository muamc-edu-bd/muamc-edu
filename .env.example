# ── Authentication ────────────────────────────────────────────────
ADMIN_UID=admin
ADMIN_PW=1234

# Flask session secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_string_before_deploying

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://hsc_academy_db_obhw_user:<password>@dpg-d8pu0r3eo5us73ai1glg-a:5432/hsc_academy_db_obhw

